# minhanr-dev local development environment
# Copy this file to .env.local and fill in real values from workspace root .env
# Production values live in Vercel → Settings → Environment Variables.

# ─── GitHub — vault read + commit URL building ────────────────────
# Token must have read access to GITHUB_REPO. Fine-grained PATs need
# the repo in the "Selected repositories" allowlist; classic PATs need
# the `repo` scope. See docs/security.md §"Vault token" for the 404
# diagnostic when GitHub returns Not Found instead of Forbidden.
GITHUB_TOKEN=
GITHUB_REPO=Minhan-Bae/oikbas-vault

# ─── GitHub webhook — vault → site rebuild trigger ────────────────
# Shared secret used by GitHub webhook delivery to sign payloads with
# HMAC-SHA256. Set the same value on the GitHub webhook configuration.
# Generate: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=

# ─── Cron secret — protects /api/cron/* routes ────────────────────
# External cron service (Vercel Cron, EasyCron, cron-job.org, etc.)
# must send `Authorization: Bearer ${CRON_SECRET}` for the route to
# accept the request (otherwise 401). Without this var, /api/cron/*
# routes return 503 (intentional, see api-auth.ts requireCronSecret).
# Generate: openssl rand -hex 32
CRON_SECRET=

# ─── Supabase — auth + tasks/quicknotes/schedules ─────────────────
# anon key: client auth flows (login page, sign-out). RLS enforces row access.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — REQUIRED for all server-side data access.
# Phase F-2-RLS (2026-04-11): API routes use createSupabaseAdmin() which
# requires this key. anon client cannot reach database tables once RLS is
# enforced. NEVER expose this key to the browser — server-only.
# Get from: https://supabase.com/dashboard/project/_/settings/api
# (copy the "service_role" key, not the "anon" key)
SUPABASE_SERVICE_KEY=

# ─── Telegram — heartbeat alerts ──────────────────────────────────
# 2026-04-26: 명명 통일. /api/cron/check-heartbeat가 ALERT 봇으로
# stale agent 알림 전송. 두 값 모두 필요 (없으면 silently skip).
# vault GHA(rt-heartbeat-monitor.yml)가 사용하는 secret 이름과 동일.
TELEGRAM_ALERT_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=

# ─── Revalidate — vault-sync → site rebuild ───────────────────────
# vault-sync.mjs가 데이터 동기화 후 /api/revalidate 호출에 사용.
# 미설정 시 즉시 반영 안 되고 다음 Vercel deploy 대기.
REVALIDATE_URL=
REVALIDATE_SECRET=
